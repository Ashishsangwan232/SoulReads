# Backend API base URL. Use the versioned surface, e.g. https://api.example.com/api/v1
VITE_API_URL=

# Firebase (used for push notifications via FCM)
VITE_FIREBASE_APIKEY=
VITE_FIREBASE_AUTHDOMAIN=
VITE_FIREBASE_PROJECTID=
VITE_FIREBASE_STORAGEBUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APPID=
VITE_FIREBASE_VAPID_KEY=

# Set to "true" to serve the maintenance page on every route instead of the app.
VITE_MAINTENANCE_MODE=false
